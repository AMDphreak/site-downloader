# Site Downloader .gitignore (Allow-list style)

# Ignore everything by default
*

# Allow directories to be traversed
!*/

# Root files
!dub.sdl
!dub.selections.json
!package.json
!pnpm-workspace.yaml
!pnpm-lock.yaml
!LICENSE
!README.adoc
!dprint.jsonc
!antora-playbook.yml
!antora-playbook-local.yml
!site-downloader.code-workspace

# Component directories
!apps/
!libs/
!docs/
!scripts/
!.github/

# Specific source file types
!**/*.d
!**/*.json
!**/*.jsonc
!**/*.adoc
!**/*.yml
!**/*.yaml
!**/*.iss
!**/*.ps1
!**/*.py
!**/*.js
!**/*.html
!**/*.css
!**/*.png
!**/*.ico

# Exclude build artifacts and temporary files
# Note: These take precedence over the allow-list above
bin/
obj/
*.exe
*.dll
*.lib
*.exp
*.pdb
.dub/
node_modules/
dist/
build/
.cache/
Output/
archives/
log_*.txt
*_log.txt
diff*.txt
err.txt
out.txt
live_*.txt
**/build*.txt
*_raw.html
**/test_archive*/
old_*.d
*.bak
*.orig
.DS_Store
Thumbs.db
